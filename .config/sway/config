# catppuccin-mocha theme:

# target                 title     bg    text   indicator  border
client.focused           $lavender $base $text  $lavender  $lavender
client.focused_inactive  $overlay0 $base $text  $overlay0  $overlay0
client.unfocused         $overlay0 $base $text  $overlay0  $overlay0
client.urgent            $red      $base $red   $red       $red
client.placeholder       $overlay0 $base $text  $overlay0  $overlay0
client.background        $base

# bar
bar {

  position top
  swaybar_command waybar
  # swaybar_command swaybar
  # status_command slstatus -s
  #
  colors {
    background         $base
    statusline         $text
    focused_statusline $text
    focused_separator  $base

    # target           border bg        text
    focused_workspace  $base  $mauve    $crust
    active_workspace   $base  $surface2 $text
    inactive_workspace $base  $base     $text
    urgent_workspace   $base  $red      $crust
  }
}


# default_border  type none if you want no border or replace the none and type pixel 4 if you want a border (choose your favorite number)
default_border pixel 1
for_window [floating] border pixel 1
for_window [floating] move position center
# smart_borders on

set $mode_borders Borders: (d) disable, (p) pixel, (n) normal
bindsym --to-code $mod+shift+b mode "$mode_borders"

mode "$mode_borders" {
    bindsym --to-code d border none
    bindsym --to-code p border pixel 1
    bindsym --to-code n border normal
    bindsym --to-code Return mode "default"
    bindsym --to-code Escape mode "default"
}


# gaps
gaps inner 20
gaps outer 1
# smart_gaps on

# Press $mod+Shift+g to enter the gap mode. 
# Choose o or i for modifying outer/inner gaps.
# Press one of + / - (in-/decrement for current workspace) 
# or 0 (remove gaps for current workspace). If you also press Shift 
# with these keys, the change will be global for all workspaces.
set $mode_gaps Gaps: (o) outer, (i) inner, (d) disable, (e) enable 
set $mode_gaps_outer Gaps Outer: [+] [-]  (local) | Shift [+] [-]  (global)
set $mode_gaps_inner Gaps Inner: [+] [-]  (local) | Shift [+] [-]  (global)
bindsym --to-code $mod+g mode "$mode_gaps"

mode "$mode_gaps" {
        bindsym --to-code o      mode "$mode_gaps_outer"
        bindsym --to-code i      mode "$mode_gaps_inner"
        bindsym --to-code d      gaps inner all set 0; gaps outer all set 0
        bindsym --to-code e      gaps inner all set 20; gaps outer all set 1

        bindsym --to-code Return mode "default"
        bindsym --to-code Escape mode "default"
}
mode "$mode_gaps_inner" {
        bindsym --to-code plus  gaps inner current plus 5
        bindsym --to-code minus gaps inner current minus 5
        bindsym --to-code Shift+plus  gaps inner all plus 5
        bindsym --to-code Shift+minus gaps inner all minus 5

        bindsym --to-code Return mode "default"
        bindsym --to-code Escape mode "default"
}
mode "$mode_gaps_outer" {
        bindsym --to-code plus  gaps outer current plus 5
        bindsym --to-code minus gaps outer current minus 5
        bindsym --to-code Shift+plus  gaps outer all plus 5
        bindsym --to-code Shift+minus gaps outer all minus 5

        bindsym --to-code Return mode "default"
        bindsym --to-code Escape mode "default"
}

# Power Profiles
set $mode_power Power Mods: (p) Performance, (b) Balanced, (s) Saver

bindsym --to-code $mod+alt+p mode "$mode_power"

mode "$mode_power" {
    bindsym --to-code b exec powerprofilesctl set balanced; mode "default"
    bindsym --to-code p exec powerprofilesctl set performance; mode "default"
    bindsym --to-code s exec powerprofilesctl set power-saver; mode "default"

    bindsym --to-code Return mode "default"
    bindsym --to-code Escape mode "default"
}

# Power Menu
set $mode_power Power Menu: (s) Shutdown, (r) Reboot, (u) Suspend, (l) Logout
set $confirm_reboot Reboot - Are you sure? (y) Yes, (n) No
set $confirm_shutdown Shutdown - Are you sure? (y) Yes, (n) No
set $confirm_suspend Suspend - Are you sure? (y) Yes, (n) No
set $confirm_logout Logout - Are you sure? (y) Yes, (n) No

mode "$mode_power" {
    bindsym --to-code s mode "$confirm_shutdown"
    bindsym --to-code r mode "$confirm_reboot"
    bindsym --to-code u mode "$confirm_suspend"
    bindsym --to-code l mode "$confirm_logout"

    bindsym --to-code Return mode "default"
    bindsym --to-code Escape mode "default"
}

mode "$confirm_reboot" {
    bindsym --to-code y exec systemctl reboot, mode "default"
    bindsym --to-code n mode "$mode_power"
    bindsym --to-code Escape mode "default"
}

mode "$confirm_shutdown" {
    bindsym --to-code y exec systemctl poweroff, mode "default"
    bindsym --to-code n mode "$mode_power"
    bindsym --to-code Escape mode "default"
}

mode "$confirm_suspend" {
    bindsym --to-code y exec systemctl suspend, mode "default"
    bindsym --to-code n mode "$mode_power"
    bindsym --to-code Escape mode "default"
}

mode "$confirm_logout" {
    bindsym --to-code y exec pkill -KILL -u $USER, mode "default"
    bindsym --to-code n mode "$mode_power"
    bindsym --to-code Escape mode "default"
}

